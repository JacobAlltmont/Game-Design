    {"$GMRUILayer":"v1","%Name":"PickaxeLayer","alignItems":2,"children":[
        {"$GMRFlexPanel":"","%Name":"NotePanel","alignItems":2,"children":[
            {"$GMRFlexPanel":"","%Name":"IntroText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_322E1824","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_322E1824","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"You spot another note near a pickaxe up ahead. This handwriting looks a little more confident.","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"IntroText1","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_299371AA","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_299371AA","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"The note says:","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText1","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"NoteText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_33196615","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":0.0,"name":"text_33196615","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.6,"scaleY":0.6,"text":"\"Hey, Oredigger.\r\n\r\nYou're going to need this. We left you a standard-issue mining pickaxe, \r\nbecause when Mines sends a student into a crisis, we at least try to send them with the proper equipment.\r\n\r\nPick it up with \"F\".\r\n\r\nOnce it's yours, press \"Q\" for a basic swing.  It's great for clearing obstacles and defending yourself.\r\n\r\nA few parts of the station have been blocked off by weak rock formations. Look for the lighter-colored stone.\r\nWhen you find it, press \"E\" to do a Super Smash and break through.\r\nThat should open new paths forward.\r\n\r\nAlso, the pickaxe has one more feature. Press \"R\" to unleash its ultimate attack. \r\nIt takes a while to recharge, so don't waste it. It hits hard and works best against larger threats.\r\nAnd by 'larger threats,' we mean the giant CU Boulder science mistake currently roaming the station.\r\n\r\nIf you forget any of this, just press \"ESC\" to view the tutorial.\r\n\r\nStay sharp, keep moving, and try not to make us regret leaving the station in the hands of one student.\r\nNo pressure.\"","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"NoteText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
