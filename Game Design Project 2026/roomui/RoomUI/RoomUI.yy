{
  "$GMRoomUI":"",
  "%Name":"RoomUI",
  "children":[
    {"$GMRUILayer":"v1","%Name":"NoteLayer","alignItems":2,"children":[
        {"$GMRFlexPanel":"","%Name":"NotePanel","alignItems":2,"children":[
            {"$GMRFlexPanel":"","%Name":"IntroText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_7513D2AE","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_7513D2AE","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"You find a crumpled note taped near the station entrance. The handwriting is rushed.","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"IntroText1","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_14CA8DA8","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_14CA8DA8","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"The note says:","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText1","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"NoteText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_2371D4E6","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":0.0,"name":"text_2371D4E6","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.6,"scaleY":0.6,"text":"\"Hey, astronaut.\r\n\r\nIf you're reading this, then you've probably already noticed one small problem: the station is completely empty.\r\n\r\nAnd before you ask, no, this is not some new independent-study survival exercise from Mines.\r\n\r\nHere's the short version: \r\nCU Boulder sent over a 'science experiment' in a secured crate and insisted it was perfectly safe. \r\nIt was, in fact, not perfectly safe.\r\n\r\nIt got out.\r\n\r\nAfter that, things became loud, expensive, and deeply unmanageable.\r\nThe crew had to evacuate before the whole station got torn apart.\r\n\r\nYou were still en route when it happened, which means you are now the only Mines astronaut left on board.\r\n\r\nSo... congratulations, and also sorry.\r\nYou are officially our last hope for saving this mining station.\r\n\r\nPlease don't let CU Boulder be the reason we lose it.\"","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"NoteText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
