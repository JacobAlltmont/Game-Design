    {"$GMRUILayer":"v1","%Name":"CrateLayer","alignItems":2,"children":[
        {"$GMRFlexPanel":"","%Name":"NotePanel","alignItems":2,"children":[
            {"$GMRFlexPanel":"","%Name":"IntroText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_5D85CA03","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_5D85CA03","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"You come across a large shipping crate stamped with a bright CU Boulder logo. \r\nThe crate has been ripped open from the inside. Whatever was in here did not leave politely.\r\nA note is still clipped to the front.","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"IntroText1","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_1869D8B7","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":6.0,"name":"text_1869D8B7","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.7,"scaleY":0.7,"text":"The note says:","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"IntroText1","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"NoteText","alignItems":2,"children":[
                {"$GMRTextItem":"v3","%Name":"text_1F457A15","alignment":0,"charSpacing":0.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"fontId":{"name":"fnt_ui","path":"fonts/fnt_ui/fnt_ui.yy",},"frameH":0.0,"frameW":0.0,"frozen":false,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"lineSpacing":0.0,"name":"text_1F457A15","paragraphSpacing":0.0,"resourceType":"GMRTextItem","resourceVersion":"2.0","rotation":0.0,"scaleX":0.6,"scaleY":0.6,"text":"\"Greetings, Mines.\r\n\r\nAs part of our continued commitment to totally normal and well-supervised scientific discovery,\r\nwe're sending over one of our latest experimental lifeforms for your review.\r\n\r\nOur team thought your station would be the perfect place to host it,\r\nsince you all enjoy rocks, caves, remote danger, and questionable engineering decisions almost as much as we do.\r\n\r\nPlease do not be alarmed by any unusual noises, property damage,\r\nmissing tools, claw marks, broken lights, or signs of aggressive intelligence. \r\nThose are all within the expected range of outcomes.\r\n\r\nProbably.\r\n\r\nWe're sure your Oredigger problem-solving skills will be more than enough to handle it.\r\n\r\nWarm regards,\r\nCU Boulder\"","wrap":false,"x":0.0,"y":0.0,},
              ],"flexDirection":0,"height":{"unit":3,"value":44.0,},"justifyContent":1,"name":"NoteText","nodeColour":4282970735,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":198.0,},},
            {"$GMRFlexPanel":"","%Name":"ResumeButton","alignItems":2,"children":[
                {"$GMRFlexPanel":"","%Name":"Icon","alignItems":2,"children":[
                    {"$GMRSpriteGraphic":"v1","%Name":"graphic_15514D6D","animationSpeed":1.0,"colour":4294967295,"flexProperties":{"$InstanceFlexProps":"v1","anchor":0,"resourceType":"InstanceFlexProps",},"frozen":false,"headPosition":0.0,"ignore":false,"inheritedItemId":null,"inheritItemSettings":false,"name":"graphic_15514D6D","resourceType":"GMRSpriteGraphic","resourceVersion":"2.0","rotation":0.0,"scaleX":1.0,"scaleY":1.0,"spriteId":{"name":"spr_ui_icon1","path":"sprites/spr_ui_icon1/spr_ui_icon1.yy",},"x":0.0,"y":0.0,},
                  ],"flexDirection":0,"height":{"unit":3,"value":48.0,},"justifyContent":1,"name":"Icon","nodeColour":4282970827,"resourceType":"GMRFlexPanel","resourceVersion":"2.0","width":{"unit":3,"value":48.0,},},
                {"$GMRFlexPanel":"","%Name":"Text","alignItems":2,"alignSelf":2,"children":[
